{
    "name": "breach",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "description": "A roguelike deckbuilder where you breach reactive computer systems — quiet-and-clever vs. loud-and-caught.",
    "scripts": {
        "dev": "vite",
        "dev:demo": "VITE_DEMO=1 vite",
        "build": "vite build",
        "build:demo": "VITE_DEMO=1 vite build --outDir dist-demo",
        "preview": "vite preview",
        "sim": "node --experimental-strip-types src/engine/sim.ts",
        "typecheck": "tsc --noEmit",
        "tauri": "tauri",
        "desktop": "tauri dev",
        "desktop:build": "tauri build",
        "desktop:demo": "VITE_DEMO=1 tauri build"
    },
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.11.4",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "typescript": "^5.6.3",
        "vite": "^5.4.11"
    }
}
